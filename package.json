{
  "name": "elliot-eval",
  "version": "0.1.0",
  "description": "Elliot Evaluation Harness — Experimentation Line-of-sight & Impact Observation Tracker",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "eval": "tsx src/index.ts",
    "eval:sample": "tsx src/index.ts --config fixtures/eval-config.json --stage screening",
    "test:screening": "tsx src/index.ts --config fixtures/eval-config.perfect.json --stage screening --failFast",
    "test:screening:perfect": "tsx src/index.ts --config fixtures/eval-config.perfect.json --stage screening --failFast",
    "test:screening:hallucinator": "tsx src/index.ts --config fixtures/eval-config.hallucinator.json --stage screening --failFast",
    "test:screening:bad-json": "tsx src/index.ts --config fixtures/eval-config.bad-json.json --stage screening --failFast",
    "test:screening:all": "F=0; npm run test:screening:perfect || F=1; npm run test:screening:hallucinator || F=1; npm run test:screening:bad-json || F=1; exit $F",
    "eval:gold": "tsx src/index.ts --config fixtures/eval-config.gold.json --stage gold",
    "test:gold": "tsx src/index.ts --config fixtures/eval-config.gold.json --stage gold --failFast --agents mock-perfect",
    "test:gold:perfect": "tsx src/index.ts --config fixtures/eval-config.gold.json --stage gold --failFast --agents mock-perfect",
    "test:gold:hallucinator": "tsx src/index.ts --config fixtures/eval-config.gold.json --stage gold --failFast --agents mock-hallucinator",
    "test:gold:bad-json": "tsx src/index.ts --config fixtures/eval-config.gold.json --stage gold --failFast --agents mock-bad-json",
    "eval:ld:screening": "tsx src/index.ts --config fixtures/eval-config.ld.json --stage screening",
    "eval:ld:gold": "tsx src/index.ts --config fixtures/eval-config.ld.json --stage gold --dataset ./data/elliot.gold.v0.1.jsonl",
    "lint:json": "node -e \"JSON.parse(require('fs').readFileSync('package.json','utf8')); console.log('package.json ok')\"",
    "eval:ld:holdout": "tsx src/index.ts --config fixtures/eval-config.holdout.json --stage gold",
    "test:curator": "tsx scripts/curator-smoke.ts",
    "test:contract-v2": "tsx scripts/contract-v2-tests.ts",
    "build:curator:synth": "tsx scripts/build-dataset-from-bundles.ts --in data/curator.synthetic.v0.1.jsonl --out data/curator.synthetic.dataset.v0.1.jsonl --tag gold",
    "eval:ld:curator-synth": "npm run build:curator:synth && tsx src/index.ts --config fixtures/eval-config.curator-synth.ld.json --stage gold",
    "test:curator-judge-e2e": "tsx scripts/curator-judge-e2e-tests.ts",
    "report:candidate": "tsx scripts/report-candidate.ts",
    "test:scout:v0": "tsx scripts/scout-v0-smoke.ts",
    "build:scout:v0:dataset": "tsx scripts/build-scout-v0-dataset.ts",
    "eval:ld:scout:v0": "npm run build:scout:v0:dataset && tsx src/index.ts --config fixtures/eval-config.scout-v0.ld.json --stage gold",
    "test:scout:salesforce": "tsx scripts/scout-salesforce-smoke.ts",
    "build:salesforce:dataset": "tsx scripts/build-salesforce-dataset.ts",
    "eval:ld:salesforce": "npm run build:salesforce:dataset && tsx src/index.ts --config fixtures/eval-config.salesforce-v1.ld.json --stage gold"
  },
  "dependencies": {
    "@launchdarkly/node-server-sdk": "^9.10.9",
    "@launchdarkly/server-sdk-ai": "^0.16.5",
    "ajv": "^8.17.1",
    "commander": "^13.1.0",
    "dotenv": "^17.3.1",
    "openai": "^6.27.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
